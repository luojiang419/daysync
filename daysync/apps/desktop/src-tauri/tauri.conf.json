{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DaySync",
  "version": "0.1.0",
  "identifier": "com.daysync.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost blob: data:; img-src 'self' asset: http://asset.localhost blob: data:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "DaySync",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
